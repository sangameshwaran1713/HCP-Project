API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Groq LLM configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=gemma2-9b-it

# Database connection URL
# Use SQLite locally: sqlite:///./crm.db
# Use MySQL: mysql+pymysql://root:password@localhost:3306/hcp_crm
DATABASE_URL=sqlite:///./crm.db

# Other integrations
JWT_SECRET=change_this_secret
ADMIN_PASSWORD=admin123
N8N_WEBHOOK_URL=http://localhost:5678/webhook/hcp-interaction

# SMTP config
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@hcp-crm.local
DEFAULT_PROVIDER_NOTIFICATION_EMAIL=
